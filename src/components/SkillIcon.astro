interface Props {
  icon: string;
}

const { icon } = Astro.props;
const resolved = customIcons[icon] ?? simpleIcons[icon as keyof typeof simpleIcons];
const fill = "hex" in resolved && resolved.hex ? `#${resolved.hex}` : "currentColor";
---

<svg
  class="skill-icon-svg"
  viewBox={resolved.viewBox ?? "0 0 24 24"}
  aria-hidden="true"
  focusable="false"
>
  <path d={resolved.path} fill={fill} />
</svg>
