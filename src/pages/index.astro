---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillIcon from "../components/SkillIcon.astro";
import { siteData } from "../data/site";

const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const resumeHref = `${assetBase}resume.pdf`;
const progressBarSegments = Array.from({ length: 32 }, (_, index) => index);
---

<BaseLayout
  title={siteData.metadata.title}
  description={siteData.metadata.description}
>
  <div class="page-shell">
    <div class="scene" aria-hidden="true">
      <div class="scene__sky"></div>
      <div class="scene__sun"></div>
      <div class="scene__glow scene__glow--left"></div>
      <div class="scene__glow scene__glow--right"></div>
      <div class="scene__grid"></div>
      <div class="scene__scanlines"></div>
      <div class="scene__noise"></div>
    </div>

    <header class="topbar">
      <div class="topbar__progress" aria-hidden="true">
        <div class="topbar__progress-track">
          <div class="topbar__progress-segments">
            {progressBarSegments.map((segment) => (
              <span class="topbar__progress-segment" data-progress-segment={segment}></span>
            ))}
          </div>
        </div>
      </div>

      <a class="topbar__brand" href="#top">
        <span class="topbar__brand-mark">CH</span>
        <span class="topbar__brand-copy">
          <span>{siteData.hero.name}</span>
          <span>{siteData.hero.title}</span>
        </span>
      </a>

      <nav class="topbar__nav" aria-label="Primary">
        <a href="#experience">Experience</a>
        <a href="#education">Education</a>
        <a href="#projects">Projects</a>
        <a href="#skills">Skills</a>
        <a href="#resume">Resume</a>
      </nav>
    </header>

    <main>
      <section class="hero section" id="top">
        <div class="hero__copy reveal" data-reveal>
          <p class="eyebrow">Developer portfolio</p>
          <h1 class="hero__name">{siteData.hero.name}</h1>
          <div class="hero__typewriter" aria-label="Professional focus">
            <span class="typewriter-text" id="typewriter"></span>
            <span class="typewriter-cursor" aria-hidden="true">|</span>
          </div>
          <p class="hero__lede">{siteData.hero.intro}</p>
          <p class="hero__summary">{siteData.hero.summary}</p>

          <div class="hero__actions">
            <a
              class="button button--primary"
              href={resumeHref}
              target="_blank"
              rel="noreferrer"
            >
              View Resume
            </a>
            <a
              class="button button--ghost"
              href={siteData.links[1].href}
              target="_blank"
              rel="noreferrer"
            >
              LinkedIn
            </a>
            <a
              class="button button--ghost"
              href={siteData.links[0].href}
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
          </div>
        </div>

        <div class="hero__facts">
          {siteData.hero.facts.map((fact) => (
            <article class="fact-card reveal" data-reveal>
              <p class="eyebrow">{fact.label}</p>
              <h2>{fact.value}</h2>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="experience">
        <div class="section-heading reveal" data-reveal>
          <p class="eyebrow">Experience</p>
          <h2>Full-stack product work at Kingsley</h2>
          <p>
            My current role at Kingsley is the clearest picture of the kind of developer
            I am: shipping production features across resident-facing applications,
            internal management tools, backend services, and database-backed workflows.
          </p>
        </div>

        <div class="kingsley-layout">
          <article
            class="feature-card feature-card--primary kingsley-overview reveal"
            data-reveal
          >
            <div class="feature-card__meta">
              <div class="feature-card__identity">
                <p class="feature-card__role">{siteData.experience.kingsley.role}</p>
                <h3>{siteData.experience.kingsley.company}</h3>
              </div>
              <div class="meta-badges">
                <span>{siteData.experience.kingsley.dates}</span>
                <span>{siteData.experience.kingsley.location}</span>
              </div>
            </div>

            <p class="feature-card__summary">
              {siteData.experience.kingsley.intro}
            </p>

            <ul class="accent-list">
              {siteData.experience.kingsley.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
          </article>

          <div class="kingsley-grid">
            {siteData.experience.kingsley.focusAreas.map((area) => (
              <article
                class:list={[
                  "feature-card",
                  "kingsley-card",
                  area.label === "Feature spotlight" && "feature-card--spotlight",
                  "reveal",
                ]}
                data-reveal
              >
                <p class="eyebrow">{area.label}</p>
                <h3>{area.title}</h3>
                <p class="feature-card__summary">{area.body}</p>

                <ul class="accent-list">
                  {area.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </div>

        <div class="section-heading section-heading--sub reveal" data-reveal>
          <p class="eyebrow">Earlier experience</p>
          <h2>Additional engineering and technical background</h2>
          <p>
            Earlier roles added backend depth, customer-facing troubleshooting, and
            research experience that still shape how I build production software.
          </p>
        </div>

        <div class="supporting-grid supporting-grid--experience">
          {siteData.experience.earlierExperience.map((job) => (
            <article class="feature-card feature-card--supporting reveal" data-reveal>
              <div class="feature-card__meta">
                <div class="feature-card__identity">
                  <p class="feature-card__role">{job.role}</p>
                  <h3 data-fit-single-line data-fit-min="18">{job.company}</h3>
                </div>
                <div class="meta-badges">
                  <span>{job.dates}</span>
                  <span>{job.location}</span>
                </div>
              </div>

              <ul class="accent-list">
                {job.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="education">
        <div class="section-heading reveal" data-reveal>
          <p class="eyebrow">Education</p>
          <h2>Computer science foundation</h2>
          <p>
            The formal foundation behind that work is a B.S. in Computer Science from
            BYU, with coursework that maps directly to software engineering, testing,
            UX, algorithms, and machine learning.
          </p>
        </div>

        <div class="education-grid">
          <article class="feature-card reveal" data-reveal>
            <div class="feature-card__meta">
              <div>
                <p class="feature-card__role">{siteData.education.degree}</p>
                <h3>{siteData.education.school}</h3>
              </div>
              <div class="meta-badges">
                <span>{siteData.education.graduation}</span>
                <span>{siteData.education.location}</span>
              </div>
            </div>

            <p class="feature-card__summary">
              Relevant coursework from the degree is listed below and reflects the areas I have spent the most time building on since graduation.
            </p>

            <ul class="tag-list">
              {siteData.education.coursework.map((course) => (
                <li>{course}</li>
              ))}
            </ul>
          </article>

          <article class="feature-card reveal" data-reveal>
            <p class="eyebrow">Conference presentation</p>
            <h3>{siteData.presentation.title}</h3>
            <p class="feature-card__summary">{siteData.presentation.description}</p>
          </article>
        </div>
      </section>

      <section class="section" id="projects">
        <div class="section-heading reveal" data-reveal>
          <p class="eyebrow">Projects</p>
          <h2>Software projects and published research</h2>
          <p>
            Beyond my professional experience, these projects and publications show how
            I approach architecture, experimentation, and technical depth.
          </p>
        </div>

        <div class="project-grid">
          {siteData.projects.map((project) => (
            <article class="project-card reveal" data-reveal>
              <div class="project-card__header">
                <div>
                  <p class="project-card__stack">{project.stack}</p>
                  <h3>{project.name}</h3>
                </div>
                <a href={project.href} target="_blank" rel="noreferrer">
                  Open
                </a>
              </div>

              <p class="project-card__summary">{project.description}</p>

              <ul class="project-card__highlights">
                {project.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <div class="section-heading section-heading--sub reveal" data-reveal>
          <p class="eyebrow">Publications</p>
          <h2>Research papers</h2>
          <p>
            These publications came out of my BYU research work and are linked directly here for quick review.
          </p>
        </div>

        <div class="publication-grid">
          {siteData.publications.map((publication) => (
            <article class="feature-card publication-card reveal" data-reveal>
              <p class="eyebrow">{publication.venue}</p>
              <h3>{publication.title}</h3>
              <p class="feature-card__summary">{publication.description}</p>
              <a
                class="button button--ghost"
                href={publication.href}
                target="_blank"
                rel="noreferrer"
              >
                Read Paper
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="skills">
        <div class="section-heading reveal" data-reveal>
          <p class="eyebrow">Skills</p>
          <h2>Skills and tech stack</h2>
          <p>
            These are the technologies I use most often in production and the adjacent
            tools I have worked with across frontend, backend, data, and cloud work.
          </p>
        </div>

        <div class="skills-grid">
          {siteData.skills.map((group) => (
            <article class="feature-card skill-category-card reveal" data-reveal>
              <h3 class="skill-category-card__title">{group.title}</h3>
              <ul class="skill-list">
                {group.items.map((item) => (
                  <li class="skill-pill">
                    <span class="skill-pill__icon" aria-hidden="true">
                      <SkillIcon icon={item.icon} />
                    </span>
                    <span>{item.label}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="resume">
        <div class="resume-card reveal" data-reveal>
          <div class="resume-card__copy">
            <p class="eyebrow">Resume</p>
            <h2>{siteData.resume.title}</h2>
            <p>{siteData.resume.copy}</p>
          </div>

          <div class="resume-card__actions">
            <a
              class="button button--primary"
              href={resumeHref}
              target="_blank"
              rel="noreferrer"
            >
              View PDF
            </a>
            <a class="button button--ghost" href={resumeHref} download>
              Download PDF
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <p>Cal Hargis · Full-Stack Software Developer</p>
      <div class="footer__links">
        {siteData.links.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
        ))}
      </div>
    </footer>
  </div>

  <script is:inline define:vars={{ typePhrases: siteData.hero.typePhrases }}>
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealItems = document.querySelectorAll("[data-reveal]");
    const glowButtons = document.querySelectorAll(".button");
    const topbar = document.querySelector(".topbar");
    const navLinks = [...document.querySelectorAll('.topbar__nav a[href^="#"]')];
    const fitSingleLineItems = [...document.querySelectorAll("[data-fit-single-line]")];
    const progressSegmentEls = [...document.querySelectorAll(".topbar__progress-segment")];
    const typewriterWrap = document.querySelector(".hero__typewriter");
    const typewriterEl = document.getElementById("typewriter");
    const typewriterCursor = document.querySelector(".typewriter-cursor");
    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;
    let pauseEnd = 0;
    let fitFrame = 0;
    let navFrame = 0;

    const trackedSections = navLinks
      .map((link) => {
        if (!(link instanceof HTMLAnchorElement)) {
          return null;
        }

        const id = link.getAttribute("href")?.slice(1);
        if (!id) {
          return null;
        }

        const section = document.getElementById(id);
        if (!(section instanceof HTMLElement)) {
          return null;
        }

        return { id, link, section };
      })
      .filter(Boolean);

    const fitTypewriterLine = () => {
      if (
        !(typewriterWrap instanceof HTMLElement) ||
        !(typewriterEl instanceof HTMLElement)
      ) {
        return;
      }

      typewriterEl.style.fontSize = "";
      typewriterEl.style.letterSpacing = "";

      const cursorWidth =
        typewriterCursor instanceof HTMLElement
          ? typewriterCursor.getBoundingClientRect().width
          : 0;
      const availableWidth = Math.max(typewriterWrap.clientWidth - cursorWidth - 8, 0);

      if (!availableWidth) {
        return;
      }

      const contentWidth = typewriterEl.scrollWidth;
      if (contentWidth <= availableWidth) {
        return;
      }

      const baseSize = parseFloat(getComputedStyle(typewriterEl).fontSize);
      const scale = availableWidth / contentWidth;
      const nextSize = Math.max(10, baseSize * scale);

      typewriterEl.style.fontSize = `${nextSize}px`;

      if (scale < 0.8) {
        typewriterEl.style.letterSpacing = "0.03em";
      } else if (scale < 0.9) {
        typewriterEl.style.letterSpacing = "0.05em";
      }
    };

    const scheduleTypewriterFit = () => {
      cancelAnimationFrame(fitFrame);
      fitFrame = requestAnimationFrame(fitTypewriterLine);
    };

    const fitSingleLineText = (element) => {
      if (!(element instanceof HTMLElement)) {
        return;
      }

      const container = element.parentElement;
      if (!(container instanceof HTMLElement)) {
        return;
      }

      element.style.fontSize = "";
      element.style.letterSpacing = "";

      const availableWidth = container.clientWidth;
      if (!availableWidth) {
        return;
      }

      const contentWidth = element.scrollWidth;
      if (contentWidth <= availableWidth) {
        return;
      }

      const baseSize = parseFloat(getComputedStyle(element).fontSize);
      const scale = availableWidth / contentWidth;
      const minSize = Number.parseFloat(element.dataset.fitMin ?? "16");
      const nextSize = Math.max(minSize, baseSize * scale);

      element.style.fontSize = `${nextSize}px`;

      if (scale < 0.88) {
        element.style.letterSpacing = "0.04em";
      }
    };

    const syncSingleLineText = () => {
      fitSingleLineItems.forEach(fitSingleLineText);
    };

    const setActiveNavLink = (activeId) => {
      trackedSections.forEach(({ id, link }) => {
        const isActive = id === activeId;
        link.classList.toggle("is-active", isActive);

        if (isActive) {
          link.setAttribute("aria-current", "location");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    const syncTopbarState = () => {
      const documentHeight = Math.max(
        document.documentElement.scrollHeight,
        document.body.scrollHeight,
      );
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const topbarHeight = topbar instanceof HTMLElement ? topbar.offsetHeight : 0;
      const activationLine = scrollTop + topbarHeight + Math.min(viewportHeight * 0.22, 108);
      const maxScroll = Math.max(documentHeight - viewportHeight, 0);
      const atPageBottom = scrollTop + viewportHeight >= documentHeight - 2;
      const progress =
        maxScroll > 0 ? (atPageBottom ? 1 : Math.min(scrollTop / maxScroll, 1)) : 1;
      let activeId = "";

      trackedSections.forEach(({ id, section }, index) => {
        if (atPageBottom) {
          activeId = trackedSections[trackedSections.length - 1]?.id ?? "";
          return;
        }

        const nextSectionTop =
          trackedSections[index + 1]?.section.offsetTop ?? Number.POSITIVE_INFINITY;

        if (activationLine >= section.offsetTop && activationLine < nextSectionTop) {
          activeId = id;
        }
      });

      const activeSegments =
        progress <= 0
          ? 0
          : Math.min(
              progressSegmentEls.length,
              Math.ceil(progress * progressSegmentEls.length),
            );

      progressSegmentEls.forEach((segment, index) => {
        if (!(segment instanceof HTMLElement)) {
          return;
        }

        segment.classList.toggle("is-active", index < activeSegments);
      });

      setActiveNavLink(activeId);
    };

    const scheduleNavSync = () => {
      cancelAnimationFrame(navFrame);
      navFrame = requestAnimationFrame(syncTopbarState);
    };

    const runTypewriter = () => {
      if (!(typewriterEl instanceof HTMLElement) || !typePhrases.length) {
        return;
      }

      const now = Date.now();
      if (now < pauseEnd) {
        requestAnimationFrame(runTypewriter);
        return;
      }

      const current = typePhrases[phraseIndex];

      if (!deleting) {
        typewriterEl.textContent = current.slice(0, charIndex + 1);
        scheduleTypewriterFit();
        charIndex += 1;

        if (charIndex === current.length) {
          deleting = true;
          pauseEnd = now + 1800;
        }
      } else {
        charIndex -= 1;
        typewriterEl.textContent = current.slice(0, charIndex);
        scheduleTypewriterFit();

        if (charIndex === 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % typePhrases.length;
          pauseEnd = now + 350;
        }
      }

      const speed = deleting ? 34 : 60;
      setTimeout(() => requestAnimationFrame(runTypewriter), speed);
    };

    if (prefersReducedMotion) {
      revealItems.forEach((item) => item.classList.add("is-visible"));
      if (typewriterEl instanceof HTMLElement && typePhrases.length) {
        typewriterEl.textContent = typePhrases[0];
        scheduleTypewriterFit();
      }
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.16,
          rootMargin: "0px 0px -36px 0px",
        },
      );

      revealItems.forEach((item) => observer.observe(item));

      if (typewriterEl instanceof HTMLElement && typePhrases.length) {
        requestAnimationFrame(runTypewriter);
      }
    }

    window.addEventListener("resize", scheduleTypewriterFit, { passive: true });
    window.addEventListener("resize", syncSingleLineText, { passive: true });
    window.addEventListener("resize", scheduleNavSync, { passive: true });
    window.addEventListener("scroll", scheduleNavSync, { passive: true });

    syncSingleLineText();
    scheduleNavSync();

    if ("fonts" in document) {
      document.fonts.ready.then(() => {
        scheduleTypewriterFit();
        syncSingleLineText();
        scheduleNavSync();
      });
    }

    glowButtons.forEach((button) => {
      if (!(button instanceof HTMLElement)) {
        return;
      }

      const updateGlow = (event) => {
        const rect = button.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;

        button.style.setProperty("--glow-x", `${x}px`);
        button.style.setProperty("--glow-y", `${y}px`);
        button.classList.add("is-glow-active");
      };

      button.addEventListener("pointerenter", updateGlow);
      button.addEventListener("pointermove", updateGlow);
      button.addEventListener("pointerleave", () => {
        button.classList.remove("is-glow-active");
      });
    });
  </script>
</BaseLayout>
